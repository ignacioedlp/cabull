// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum AppointmentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

/**
 * =========================
 * DOMAIN: CABULL
 * =========================
 */

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  durationMinutes Int      @default(30) @map("duration_minutes") // Ej: Corte 30, Corte+Barba 45
  basePrice       Int?     @map("base_price") // en ARS (opcional)
  active          Boolean  @default(true)
  features        String[] @map("features")

  appointments           Appointment[]
  preferredByUsers       User[] @relation("UserPreferredService")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active])
  @@map("services")
}

model BusinessHours {
  id        String  @id @default(cuid())
  weekday   Int // 0=Dom ... 6=Sáb
  startTime String  @map("start_time") // "09:00" (simple y práctico)
  endTime   String  @map("end_time") // "18:30"
  isClosed  Boolean @default(false) @map("is_closed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([weekday])
  @@map("business_hours")
}

model BusinessRules {
  id                  String   @id @default(cuid())
  reservationWindow   Int      @map("reservation_window")
  reservationInterval Int      @map("reservation_interval")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("business_rules")
}

model Appointment {
  id String @id @default(cuid())

  // Cliente
  customerEmail String  @map("customer_email")
  customerId    String? @map("customer_id") // Es opcional a menos que el cliente esté registrado
  customer      User?   @relation("CustomerAppointments", fields: [customerId], references: [id])

  // Servicio
  serviceId String  @map("service_id")
  service   Service @relation(fields: [serviceId], references: [id])

  // Horario
  startAt DateTime @map("start_at")

  status AppointmentStatus @default(PENDING_CONFIRMATION)

  // Confirmación por email (cliente)
  confirmationTokenHash String?   @map("confirmation_token_hash")
  confirmationExpiresAt DateTime? @map("confirmation_expires_at")

  // Admin/Barbero: cierre del turno
  totalCost Int?    @map("total_cost") // costo final (ARS)
  notes     String?

  // Barbero (User con role = BARBER)
  barberId String @map("barber_id")
  barber   User   @relation("BarberAppointments", fields: [barberId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Evita doble reserva del mismo horario (para 1 barbero).
  @@unique([barberId, startAt])
  @@index([status, startAt])
  @@index([customerEmail])
  @@index([serviceId, startAt])
  @@map("appointments")
}

/**
 * =========================
 * ADMIN AUTH (ALLOWLIST / ROLES)
 * - Útil si querés staff y control desde DB
 * - Better Auth puede usar estas tablas como "user" si tu adapter lo permite,
 * o podés mantenerlo separado (y usar allowlist por env).
 * =========================
 */

enum UserRole {
  CUSTOMER
  BARBER
  STAFF
  OWNER
}

/**
 * =========================
 * USER TYPES
 * =========================
 */

enum UserType {
  VIP
  REGULAR
  NEW
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      Boolean   @default(false) @map("email_verified")
  name               String?
  phone              String?
  image              String?                           // avatar de Google
  googleId           String?   @unique @map("google_id")

  // Control de acceso
  role               UserRole  @default(CUSTOMER) @map("role")
  active             Boolean   @default(true)

  // CRM (solo relevante para CUSTOMER)
  userType           UserType  @default(REGULAR) @map("user_type")
  notes              String?
  preferredServiceId String?   @map("preferred_service_id")
  preferredService   Service?  @relation("UserPreferredService", fields: [preferredServiceId], references: [id])

  // Barbero (solo relevante para BARBER)
  color              String?   // color en el calendario

  appointments       Appointment[] @relation("CustomerAppointments")
  barberAppointments Appointment[] @relation("BarberAppointments")

  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([role, active])
  @@map("users")
}

// Para "magic link / email verification" (token de un solo uso)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
  @@map("verification_tokens")
}

// Para rate limiting por IP (control de intentos de reserva)
model RateLimitAttempt {
  id        String   @id @default(cuid())
  ipAddress String   @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") // Para limpieza automática

  @@index([ipAddress, createdAt])
  @@index([expiresAt]) // Para limpieza eficiente de registros expirados
  @@map("rate_limit_attempts")
}

/**
 * =========================
 * SESSION TABLES
 * - Tablas para el sistema de autenticación con magic links
 * =========================
 */

// Sesiones de autenticación (DEPRECATED - replaced by JWT auth in Auth.js)
model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// Cuentas vinculadas (Better Auth OAuth)
model Account {
  id                     String    @id @default(cuid())
  userId                 String    @map("user_id")
  accountId              String    @map("account_id")
  providerId             String    @map("provider_id")
  accessToken            String?   @map("access_token")
  refreshToken           String?   @map("refresh_token")
  idToken                String?   @map("id_token")
  accessTokenExpiresAt   DateTime? @map("access_token_expires_at")
  expiresAt              DateTime? @map("expires_at")
  password               String?
  scope                  String?
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

// Verificaciones (Better Auth)
model Verification {
  id        String   @id @default(cuid())
  identifier String
  value     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([identifier, value])
  @@index([expiresAt])
  @@map("verifications")
}
